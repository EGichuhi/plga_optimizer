// .devcontainer/devcontainer.json
{
  "name": "PLGA Drug Delivery Optimizer",
  "image": "mcr.microsoft.com/devcontainers/python:3.9",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {}
  },
  "postCreateCommand": "bash setup.sh",
  "postStartCommand": "bash run.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "GitHub.copilot"
      ],
      "settings": {
  "python.defaultInterpreterPath": "/workspaces/plga_optimizer/plga_venv/bin/python",  
  "terminal.integrated.defaultProfile.linux": "bash"
},
  "postStartCommand": "bash run.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/plga_optimizer/plga_venv/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash",
        // Add this line:
        "terminal.integrated.env.linux": {
          "VIRTUAL_ENV": "/workspaces/plga_optimizer/plga_venv",
          "PATH": "/workspaces/plga_optimizer/plga_venv/bin:${env:PATH}"
        }
      }
    }
  }
    }
  },
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "notify"
    }
  }
}

